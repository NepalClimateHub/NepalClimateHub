<style>
  .why-support-section {
    background-color: #f3f4f6;
    padding: 4rem 0;
  }

  .section-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0;
    font-family: Roboto, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .why-support-header {
    margin-bottom: 24px;
  }

  .why-support-title {
    font-family: "Zilla Slab", serif;
    font-size: 30px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 8px;
  }

  .why-support-subtitle {
    font-size: 16px;
    color: #4b5563;
    margin: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .support-card {
    background-color: #cefe00;
    border-radius: 16px;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .icon-wrapper {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background-color: #1a1b1e;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-title {
    font-size: 18px;
    font-weight: 600;
    color: #111827;
    margin: 0;
  }

  .card-body {
    font-size: 14px;
    line-height: 20px;
    color: #111827;
    margin: 0;
    margin-left: 52px; /* icon (40px) + gap (12px) */
  }

  @media (max-width: 1280px) {
    .section-container {
      padding: 0 48px;
    }
  }

  @media (max-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .section-container {
      padding: 0 24px;
