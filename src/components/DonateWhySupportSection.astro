---
const cards = [
  {
    title: 'Share accessible climate knowledge',
    body: 'through beginner-friendly explainers, guides, tools, and curated stories grounded in Nepal’s context',
    icon: 'bookmarks',
  },
  {
    title: 'Connect people working in climate',
    body: 'by creating online and offline spaces for youth, professionals, researchers, activists, and organizations to collaborate and grow',
    icon: 'user',
  },
  {
    title: 'Support youth-led climate action',
    body: 'by sharing jobs, internships, fellowships, volunteering opportunities, and highlighting youth leaders, activists, and practitioners',
    icon: 'hands',
  },
  {
    title: 'Strengthen Nepal’s climate ecosystem',
    body: 'by reducing information gaps and improving coordination',
    icon: 'globe',
  },
  {
    title: 'Amplify work on climate',
    body: 'through stories, blogs, and profiles, helping broaden reach, visibility, and impact',
    icon: 'pen',
  },
  {
    title: 'Build open, transparent tools',
    body: 'that are accessible and built in public',
    icon: 'tools',
  },
];
