---
const qualificationItems = [
  {
    title: "Academic Stage",
    bgColor: "#CCD3F1",
    points: [
      "Bachelor's students (Final semester)",
      "Master's students",
      "Recent graduates"
    ]
  },
  {
    title: "Academic Background",
    bgColor: "#E0E7FF",
    points: [
      "Environmental science",
      "Forestry",
      "Agriculture",
      "Related disciplines"
    ]
  },
  {
    title: "Time Commitment",
    bgColor: "#EAEDF9",
    points: [
      "8–10 hours per week",
      "Self-paced + guided sessions",
      "Remote-friendly"
    ]
  }
];
---

<div class="section-wrapper">
  <div class="section-container">
    <div class="section-header">
      <h2 class="section-title">Built for motivated emerging professionals</h2>
      <p class="section-description">
        You don't need prior coding experience—just curiosity, commitment and a desire to make environmental data work for Nepal.
      </p>
    </div>

    <div class="qualifications-layout">
      <div class="qualifications-cards">
        {qualificationItems.map((item) => (
          <div class="qualification-card" style={`background-color: ${item.bgColor}`}>
            <h3 class="card-title">{item.title}</h3>
            <ul class="card-points">
              {item.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="section-image">
    <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=600&fit=crop" alt="Fellowship participants" />
  </div>
</div>

<style>
  .section-wrapper {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-container {
    width: 100%;
  }

  .section-header {
    max-width: 45%;
  }

  .section-title {
    font-family: 'Zilla Slab', serif;
    font-size: 36px;
    font-weight: 600;
    color: #1A1B1E;
    margin-top: 24px;
    margin-bottom: 0;
    line-height: 44px;
  }

  .section-description {
    font-size: 20px;
    font-weight: 400;
    color: #64748B;
    line-height: 160%;
    margin-top: 24px;
    margin-bottom: 0;
  }

  .qualifications-layout {
    margin-top: 44px;
  }

  .qualifications-cards {
    display: flex;
    flex-direction: row;
    gap: 24px;
    position: relative;
    z-index: 1;
  }

  .qualification-card {
    padding: 24px;
    border-radius: 12px;
    max-width: fit-content;
  }

  .card-title {
    font-size: 20px;
    font-weight: 600;
    color: #1A1B1E;
    line-height: 160%;
    margin: 0;
  }

  .card-points {
    list-style: none;
    padding: 0;
    margin: 16px 0 0 0;
  }

  .card-points li {
    font-size: 16px;
    font-weight: 400;
    color: #1A1B1E;
    line-height: 160%;
    margin-bottom: 12px;
    padding-left: 20px;
    position: relative;
  }

  .card-points li:last-child {
    margin-bottom: 0;
  }

  .card-points li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #364FC7;
  }

  .section-image {
    width: 47%;
    border-radius: 12px;
    overflow: hidden;
    position: absolute;
    right: 0;
    bottom: 0;
    top: 0;
    z-index: 0;
  }

  .section-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1024px) {
    .section-title {
      font-size: 30px;
      line-height: 36px;
    }

    .section-description {
      font-size: 18px;
    }

    .section-header {
      max-width: 80%;
    }

    .section-image {
      display: none;
    }

    .card-title {
      font-size: 18px;
    }
  }

  @media (max-width: 768px) {
    .section-header {
      max-width: 100%;
    }

    .section-title {
      font-size: 26px;
      line-height: 32px;
    }

    .section-description {
      font-size: 16px;
      margin-top: 16px;
    }

    .qualifications-cards {
      flex-wrap: wrap;
    }

    .section-image {
      width: 45%;
    }

    .card-title {
      font-size: 16px;
    }

    .card-points li {
      font-size: 15px;
    }
  }

  @media (max-width: 480px) {
    .section-title {
      font-size: 22px;
      line-height: 28px;
    }

    .section-description {
      font-size: 15px;
    }

    .qualifications-layout {
      margin-top: 32px;
    }

    .qualifications-cards {
      flex-direction: column;
      gap: 16px;
    }

    .qualification-card {
      max-width: 100%;
    }

    .section-image {
      width: 45%;
    }

    .card-title {
      font-size: 16px;
    }

    .card-points li {
      font-size: 14px;
    }
  }
</style>