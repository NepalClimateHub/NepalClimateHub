---
---

<section class="contribution-section">
  <div class="section-container">
    <div class="contribution-grid">
      <div class="contribution-text">
        <p class="contribution-line">
          <span>Every</span>
        </p>
        <p class="contribution-line">
          <span>contribution</span>
        </p>
        <p class="contribution-line">
          <span>helps keep </span>
          <span class="contribution-strong">NCH</span>
        </p>
        <p class="contribution-line">
          <span class="contribution-strong">free</span>
          <span> and</span>
        </p>
        <p class="contribution-line">
          <span class="contribution-strong">accessible.</span>
        </p>
      </div>

      <div class="contribution-image">
        <img
          src="https://ik.imagekit.io/mbccqjudb/donate%20page/image%20134.png"
          alt="People gathering in a square holding climate action signs"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .contribution-section {
    background-color: #ffffff;
    padding: 4rem 0;
  }

  .section-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0;
  }

  .contribution-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 40px;
    align-items: center;
  }

  .contribution-text {
    font-family: "Zilla Slab", serif;
    font-weight: 600;
    font-size: 60px;
    line-height: 1.05;
    color: #111827;
    max-width: 480px;
  }

  .contribution-line {
    margin: 0;
  }

  .contribution-strong {
    font-weight: 700;
  }

  .contribution-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 8px;
  }

  @media (max-width: 1024px) {
    .section-container {
      padding: 0 48px;
    }

    .contribution-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    .section-container {
      padding: 0 24px;
    }

    .contribution-section {
      padding: 3rem 0;
    }

    .contribution-text {
      font-size: 34px;
      line-height: 1.1;
      max-width: none;
    }
  }
</style>

