---
import { RiAlarmLine } from "react-icons/ri";
import { createSlug } from 'src/utils/slug';
import type { Project } from 'src/types/project';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="explore-section">
  <div class="section-container">
    <h2 class="section-title">Explore our work</h2>
    <p class="section-description">
      Our ongoing, completed, and upcoming projects and initiatives
    </p>

    <div class="grid">
      {projects.length > 0 ? (
        projects.map((project) => (
          <a href={`/our-work/${createSlug(project.title)}`} class="card-link">
            <div class="card">
              <div class="card-image">
                <img src={project.bannerImageUrl} alt={project.title} />
              </div>
              <div class="card-content">
                <h3 class="card-title">{project.title}</h3>
                <p class="card-overview">
                  <span class="overview-label">Overview:</span> {project.overview}
                </p>

                <div class="card-duration">
                  <RiAlarmLine size={15} />
                  <span class="duration-text">
                    <span class="duration-label">Duration:</span> {project.duration}
                  </span>
                </div>

                <div class="card-tags">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag.tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))
      ) : (
        <div class="no-projects">No projects found</div>
      )}
    </div>
  </div>
</section>

<style>
  .explore-section {
    padding: 35px 48px;
    background-color: #ffffff;
  }

  .section-container {
    /* max-width: 984px; */
    margin: 0 auto;
  }

  .section-title {
    font-size: 20px;
    color: #1a1b1e;
    line-height: 32px;
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .section-description {
    font-size: 16px;
    color: #1a1b1e;
    line-height: 24px;
    margin: 0 0 32px 0;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    grid-auto-rows: 1fr;
    gap: 16px;
    margin-bottom: 110px;
  }

  .no-projects {
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px 24px;
    color: #464646;
    font-size: 16px;
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-link:hover {
    transform: translateY(-4px);
  }

  .card-link:hover .card {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .card {
    border-radius: 12px;
    padding: 12px;
    background-color: #f8f9fa;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    width: 100%;
    transition: box-shadow 0.2s ease;
  }

  .card-image {
    width: 100%;
    height: 200px;
    margin-bottom: 12px;
    border-radius: 8px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card-title {
    font-size: 16px;
    color: #1a1b1e;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
  }

  .card-overview {
    font-size: 12px;
    color: #464646;
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .overview-label {
    font-weight: 700;
  }

  .card-duration {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #464646;
  }

  .card-duration :global(svg) {
    color: #d9d9d9;
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }

  .duration-text {
    display: flex;
    gap: 4px;
  }

  .duration-label {
    font-weight: 700;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .tag {
    padding: 4px 9px;
    background-color: transparent;
    border: 1px solid #cefe00;
    border-radius: 20px;
    font-size: 12px;
    color: #364fc7;
    font-weight: 500;
  }

  @media screen and (max-width: 1280px) {
    .explore-section {
      padding: 35px 24px;
    }

    .grid {
      grid-template-columns: 1fr 1fr 1fr;
      margin-bottom: 80px;
    }
  }

  @media screen and (max-width: 768px) {
    .explore-section {
      padding: 24px 24px;
    }

    .section-title {
      font-size: 18px;
    }

    .grid {
      grid-template-columns: 1fr;
      margin-bottom: 32px;
    }

    .card {
      padding: 12px;
    }
  }
</style>
