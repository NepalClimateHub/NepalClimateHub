      <!-- SEO Strategist -->
      <article class="role-card" data-role="seo-strategist">
        <header class="role-card__head">
          <div class="role-card__title-block">
            <h3 class="role-title">SEO Strategist</h3>
            <div class="role-badges" role="list">
