<style>
  .section-container {
    max-width: 1280px;
    margin: 0 auto;
    margin-bottom: 120px;
  }

  .open-roles-section {
    margin-top: 0;
  }

  .sub-heading {
    font-size: clamp(22px, 2.5vw, 28px);
    line-height: 1.25;
    font-weight: 700;
    margin: 0 0 12px;
    color: #1a1b1e;
  }

  .roles-intro {
    max-width: none;
    font-size: 17px;
    line-height: 1.55;
    margin: 0 0 32px;
    color: #4b5563;
    text-wrap: pretty;
  }

  .roles-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 0;
  }

  .role-card {
    width: 100%;
    background: #ffffff;
    border: 1px solid #e8eaed;
    border-radius: 20px;
    padding: clamp(20px, 3vw, 28px) clamp(20px, 3vw, 32px);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 4px 16px rgba(15, 23, 42, 0.05);
    display: flex;
    flex-direction: column;
    gap: 0;
    transition:
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .role-card:hover {
    border-color: #d4e85a;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.06),
      0 8px 24px rgba(15, 23, 42, 0.08);
  }

  .role-card__head {
    padding-bottom: 16px;
    border-bottom: 1px solid #f1f3f5;
    margin-bottom: 16px;
  }

  .role-card__title-block {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 16px;
  }

  .role-title {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 700;
    color: #1a1b1e;
    margin: 0;
    line-height: 1.2;
  }

  .role-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .role-badge {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    padding: 5px 12px;
    border-radius: 999px;
    background: #cefe00;
    color: #1a1b1e;
  }

  .role-badge--muted {
    background: #f1f3f5;
    color: #495057;
    font-weight: 500;
  }

  .role-lead {
    font-size: 15px;
    line-height: 1.6;
    color: #495057;
    margin: 0 0 20px;
  }

  .role-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(12px, 2vw, 20px);
    margin-bottom: 20px;
  }

  .role-card__foot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid #f1f3f5;
  }

  .role-panel {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 16px;
    border: 1px solid #eef0f2;
  }

  .role-panel__title {
    font-size: 14px;
    font-weight: 700;
    color: #1a1b1e;
    margin: 0 0 12px;
    letter-spacing: 0.01em;
  }

  .role-list {
    margin: 0;
    padding-left: 1.1rem;
  }

  .role-list li {
    margin-bottom: 8px;
    line-height: 1.5;
    color: #374151;
    font-size: 14px;
  }

  .role-list li:last-child {
    margin-bottom: 0;
  }

  .role-list li::marker {
    color: #364fc7;
  }

  .apply-button:focus-visible {
    outline: 2px solid #364fc7;
    outline-offset: 2px;
  }

  .apply-button:active {
    transform: scale(0.99);
  }

  .apply-button--wide {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 12px 20px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    background: #cefe00;
    color: #1a1b1e;
    transition:
      background 0.2s ease,
      transform 0.15s ease;
  }

  .apply-button--wide:hover {
    background: #b8e600;
    color: #1a1b1e;
  }

  .role-footnote {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: #6b7280;
    text-align: center;
  }

  .role-footnote a {
    color: #364fc7;
    font-weight: 500;
    text-decoration: none;
  }

  .role-footnote a:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 1280px) {
    .section-container {
      padding: 40px 48px;
      margin-bottom: 50px;
    }
  }

  @media screen and (max-width: 768px) {
    .section-container {
      padding: 20px 24px;
      margin-bottom: 32px;
    }

    .role-content {
      grid-template-columns: 1fr;
    }

    .role-card__title-block {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }

  @media screen and (max-width: 480px) {
    .role-card {
      padding: 18px 16px;
      border-radius: 16px;
    }

    .role-panel {
      padding: 14px;
    }
  }
</style>
