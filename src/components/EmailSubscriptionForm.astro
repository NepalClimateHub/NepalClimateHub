---
interface Props {
  formBtnVariant?: 'primary' | 'secondary';
}

const { formBtnVariant = 'primary' } = Astro.props;
---

<div class="email-subscription">
  <h3 class="subscription-title">Stay Updated</h3>
  <p class="subscription-description">
    Get the latest climate insights and updates delivered to your inbox.
  </p>

  <form class="subscription-form" method="POST" action="/api/subscribe">
    <div class="input-group">
      <input
        type="email"
        name="email"
        placeholder="Enter your email address"
        class="email-input"
        required
      />
      <button
        type="submit"
        class={`subscribe-btn ${formBtnVariant === 'secondary' ? 'btn-secondary' : 'btn-primary'}`}
      >
        Subscribe
      </button>
    </div>
  </form>

  <p class="privacy-note">
    We respect your privacy. Unsubscribe at any time.
  </p>
</div>

