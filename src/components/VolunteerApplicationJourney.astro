---
import {  FiUserCheck, FiFileText, FiCheckSquare, FiMessageCircle, FiMail, FiZap } from 'react-icons/fi';
import { IoChatbubbleOutline, IoVideocamOutline  } from "react-icons/io5";
import { IoMdCheckmarkCircleOutline } from "react-icons/io";
import { BsClipboard2Check } from "react-icons/bs";
import { RiChat3Line } from "react-icons/ri";
import { LuClipboardCheck, LuVideo  } from "react-icons/lu";
---

<div class="section-container">
  <h2 class="section-title">Your Application Journey</h2>
  <p class="section-description">
    Joining our team is more than just volunteering - you will become part of a
    purpose-driven team whose members show up for each other as much as for
    NCH's mission. We carefully select individuals who are collaborative,
    reliable, and deeply motivated to create impact.
  </p>

  <div class="journey-grid">
    <!-- Card 1 -->
    <div class="journey-card">
      <div class="card-number">1</div>
      <div class="card-icon">
        <FiFileText size={28} color="#1A1B1E" />
      </div>
      <div class="card-text">
        <h3 class="card-title">Apply online</h3>
        <p class="card-description">
          Submit your application and tell us about your interests, skills, and motivations.
        </p>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="journey-card">
      <div class="card-number">2</div>
      <div class="card-icon">
        <FiUserCheck size={28} color="#1A1B1E" />
      </div>
      <div class="card-text">
        <h3 class="card-title">Profile screening</h3>
        <p class="card-description">
          We review your background, commitment, and alignment with our mission and values.
        </p>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="journey-card">
      <div class="card-number">3</div>
      <div class="card-icon">
        <RiChat3Line size={28} color="#1A1B1E" />
      </div>
      <div class="card-text">
        <h3 class="card-title">Screening call</h3>
        <p class="card-description">
          A short conversation to get to know you, your goals, and how you communicate. You will also get to know us!
        </p>
      </div>
    </div>

    <!-- Card 4 -->
    <div class="journey-card">
      <div class="card-number">4</div>
      <div class="card-icon">
        <LuClipboardCheck size={28} color="#1A1B1E" />
      </div>
      <div class="card-text">
        <h3 class="card-title">Assessment</h3>
        <p class="card-description">
          A short, practical task related to the role to understand your approach and creativity.
        </p>
      </div>
    </div>

    <!-- Card 5 -->
    <div class="journey-card">
      <div class="card-number">5</div>
      <div class="card-icon">
        <LuVideo size={28} color="#1A1B1E" />
      </div>
      <div class="card-text">
        <h3 class="card-title">Virtual interview</h3>
        <p class="card-description">
          A deeper discussion with our team to explore fit, expectations, and working style.
        </p>
      </div>
    </div>

    <!-- Card 6 -->
    <div class="journey-card">
      <div class="card-number">6</div>
      <div class="card-icon">
        <IoMdCheckmarkCircleOutline size={28} color="#1A1B1E" />
      </div>
      <div class="card-text">
        <h3 class="card-title">Onboarding</h3>
        <p class="card-description">
          Congrats - you made it! Your onboarding to our team begins.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .section-container {
    max-width: 1280px;
    margin: 0 auto;
    margin-bottom: 120px;
  }

  .section-title {
    font-family: "Zilla Slab", serif;
    font-size: 30px;
    font-weight: 700;
    color: #1a1b1e;
    margin: 0;
  }

  .section-description {
    font-size: 18px;
    line-height: 24px;
    color: #333;
    margin-top: 16px;
    margin-bottom: 0;
  }

  .journey-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 48px;
  }

  .journey-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .card-number {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: transparent;
    border: 2px solid #1a1b1e;
    color: #1a1b1e;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  .card-icon {
    display: flex;
  }

  .card-text {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-title {
    font-weight: 700;
    font-size: 18px;
    color: #1a1b1e;
    margin: 0;
  }

  .card-description {
    font-size: 16px;
    line-height: 24px;
    color: #4a5565;
    margin: 0;
  }

  @media screen and (max-width: 1280px) {
    .section-container {
      padding: 40px 48px;
      margin-bottom: 50px;
    }
  }

  @media screen and (max-width: 992px) {
    .journey-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media screen and (max-width: 768px) {
    .section-container {
      padding: 20px 24px;
      margin-bottom: 32px;
    }

    .journey-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .section-title {
      font-size: 24px;
      line-height: 32px;
    }
  }
</style>
