---
const items = [
  'Platform development and maintenance',
  'Educational content and research',
  'Community programs and outreach',
  'Youth engagement and capacity-building',
  'Essential operational costs',
];
---

<section class="how-used-section">
  <div class="section-container">
    <div class="how-used-grid">
      <div class="how-used-left">
        <h2 class="how-used-title">
          How your
          <br />
          donation is used
        </h2>
        <p class="how-used-subtitle">
          We believe in transparency and impact. Your support directly funds these key areas.
        </p>
      </div>

      <div class="how-used-right">
        <ul class="how-used-list">
          {items.map((item, index) => (
            <li class="how-used-item">
              <span class="how-used-number">
                {String(index + 1).padStart(2, '0')}
              </span>
              <span class="how-used-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .how-used-section {
    background-color: #ffffff;
    padding: 4rem 0;
  }

  .section-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0;
    font-family: Roboto, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .how-used-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 64px;
    align-items: flex-start;
  }

  .how-used-left {
    padding-right: 24px;
  }

  .how-used-title {
    font-family: "Zilla Slab", serif;
    font-size: 40px;
    line-height: 1.15;
    font-weight: 700;
    color: #111827;
    margin: 0 0 16px;
  }

  .how-used-subtitle {
    font-size: 16px;
    line-height: 24px;
    color: #4b5563;
    margin: 0;
    max-width: 320px;
  }

  .how-used-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid #e5e7eb;
  }

  .how-used-item {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    align-items: center;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .how-used-number {
    font-family: "Zilla Slab", serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: #111827;
  }

  .how-used-text {
    font-family: Roboto, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 18px;
    line-height: 26px;
    color: #111827;
  }

  @media (max-width: 1280px) {
    .section-container {
      padding: 0 48px;
    }
  }

  @media (max-width: 1024px) {
    .how-used-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .how-used-left {
      padding-right: 0;
    }
  }

  @media (max-width: 768px) {
    .section-container {
      padding: 0 24px;
    }

    .how-used-section {
      padding: 3rem 0;
    }

    .how-used-title {
      font-size: 30px;
    }
  }
</style>

