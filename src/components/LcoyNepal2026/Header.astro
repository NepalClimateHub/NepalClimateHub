---
import lcoyLogo from '../../assets/lcoy/logo/lcoyLogo.jpg';

const navItems = [
  { id: 'home', label: 'Home' },
  { id: 'about', label: 'About' },
  { id: 'objectives', label: 'Objectives' },
  { id: 'speakers', label: 'Speakers' },
  { id: 'faq', label: 'FAQ' },
];
---

<header class="lcoy-header">
  <div class="header-inner">
    <a class="logo-link" href="#home" aria-label="LCOY Nepal 2026 home">
      <img src={lcoyLogo.src} alt="LCOY Nepal 2026 logo" />
    </a>

    <nav class="nav-links" aria-label="Page navigation">
      {navItems.map((item) => (
        <a class="nav-link" href={`#${item.id}`} data-target={item.id}>
          {item.label}
        </a>
      ))}
    </nav>

    <a class="cta-button" href="#about">Register Now</a>
  </div>
</header>

<script type="module">
  const updateActiveNav = () => {
    const currentHash = window.location.hash || '#home';
    document.querySelectorAll('.nav-link').forEach((link) => {
      link.classList.toggle('active', link.getAttribute('href') === currentHash);
    });
  };

  window.addEventListener('hashchange', updateActiveNav);
  window.addEventListener('DOMContentLoaded', updateActiveNav);
</script>

<style>
.lcoy-header {
  padding: 16px 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  max-width: 1280px;
  margin: 0 auto;
}

.logo-link img {
  display: block;
  max-height: 40px;
  width: auto;
}

.nav-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  flex: 1;
}

.nav-link {
  color: #404943;
  font-size: 12px;
  line-height: 12px;
  letter-spacing: 1.2px;
  font-weight: 700;
  text-decoration: none;
  border-bottom: 2px solid transparent;
  padding-bottom: 4px;
}

.nav-link.active {
  color: #00442D;
  border-color: #00442D;
}

.cta-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #1D5C42;
  color: white;
  border-radius: 12px;
  padding: 14px 36px;
  font-size: 12px;
  line-height: 12px;
  letter-spacing: 1.2px;
  font-weight: 700;
  text-decoration: none;
}

@media screen and (max-width: 768px) {
  .header-inner {
    flex-wrap: wrap;
  }

  .nav-links {
    order: 3;
    width: 100%;
    justify-content: space-between;
    gap: 16px;
  }

  .cta-button {
    order: 2;
  }
}
</style>
