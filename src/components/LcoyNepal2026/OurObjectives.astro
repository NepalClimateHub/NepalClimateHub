<style>
  .objectives-section {
    background: #1D5C42;
    color: white;
    padding: 96px 64px;
  }

  .objectives-inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 56px;
    text-align: center;
    width: 100%;
  }

  .section-title {
    font-family: 'Poppins', sans-serif;
    font-size: 32px;
    line-height: 42px;
    font-weight: 600;
    text-transform: capitalize;
    color: rgba(255, 255, 255, 0.85);
  }

  .objectives-section h2 {
    color: white;
    font-size: clamp(32px, 3vw, 44px);
    line-height: 1.1;
    margin: 0;
  }

  .objectives-section p {
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    font-size: clamp(16px, 1vw, 18px);
    line-height: 1.8;
  }

  .objectives-grid {
    display: flex;
    gap: 24px;
    justify-content: center;
  }

  .objectives-grid-two {
    display: flex;
    gap: 24px;
    margin-top: 32px;
    justify-content: center;
  }

  .objective-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 24px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-height: 240px;
    align-items: center;
    max-width: 270px;
  }

  .objective-card svg {
    flex-shrink: 0;
  }

  .objective-card p {
    font-family: 'Poppins', sans-serif;
    font-size: 20px;
    font-weight: 500;
    line-height: 1.5;
    color: white;
    margin: 0;
    text-align: center;
  }

  @media screen and (max-width: 1024px) {
    .objectives-section {
      padding: 72px 40px;
    }

    .objectives-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-title {
      font-size: 28px;
      line-height: 36px;
    }

    .objective-card p {
      font-size: 18px;
    }
  }

  @media screen and (max-width: 768px) {
    .objectives-section {
      padding: 56px 24px;
    }

    .objectives-grid {
      flex-direction: column;
      justify-content: start;
      align-items: center;
    }

    .objectives-grid-two {
      flex-direction: column;
      justify-content: start;
      align-items: center;
    }

    .section-title {
      font-size: 24px;
      line-height: 32px;
    }

    .objectives-section p {
      font-size: 15px;
    }

    .objective-card p {
      font-size: 16px;
    }
  }

  @media screen and (max-width: 480px) {
    .objectives-section {
      padding: 48px 16px;
    }

    .objective-card {
      padding: 24px;
      min-height: auto;
    }

    .section-title {
      font-size: 20px;
      line-height: 28px;
    }

    .objectives-section p {
      font-size: 14px;
    }

    .objective-card p {
      font-size: 14px;
    }
  }
</style>