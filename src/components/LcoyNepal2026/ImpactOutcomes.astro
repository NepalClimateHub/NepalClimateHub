20.1562 5.72396 19.8125 6.29167 19.3125 6.9375C18.8125 7.58333 18.1146 8.34896 17.2188 9.23438C16.3229 10.1198 15.1667 11.2083 13.75 12.5ZM13.75 9.125C15.25 7.75 16.3542 6.63021 17.0625 5.76562C17.7708 4.90104 18.125 4.22917 18.125 3.75C18.125 3.39583 18 3.09896 17.75 2.85938C17.5 2.61979 17.1979 2.5 16.8438 2.5C16.5938 2.5 16.349 2.57292 16.1094 2.71875C15.8698 2.86458 15.625 3.08333 15.375 3.375L13.7812 5.21875L12.1875 3.4375C11.8958 3.10417 11.6302 2.86458 11.3906 2.71875C11.151 2.57292 10.9062 2.5 10.6562 2.5C10.3021 2.5 10 2.61979 9.75 2.85938C9.5 3.09896 9.375 3.39583 9.375 3.75C9.375 4.22917 9.72917 4.90104 10.4375 5.76562C11.1458 6.63021 12.25 7.75 13.75 9.125Z" fill="#E5B63B"/>
    </svg>
`,
    title: "Strengthened Youth Leadership",
    description:
      "Strengthening the capacity of young Nepalese climate advocates in policy engagement, advocacy, and leadership.",
  },
  {
    icon: `<svg width="25" height="15" viewBox="0 0 25 15" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1.75 15L0 13.25L9.25 3.9375L14.25 8.9375L20.75 2.5H17.5V0H25V7.5H22.5V4.25L14.25 12.5L9.25 7.5L1.75 15Z" fill="#F06C5D"/>
    </svg>`,
    title: "Policy Engagement",
    description:
      "Increasing engagement of government officials and policymakers with youth perspectives on climate change.",
  },
];
---

<section id="impact-outcomes" class="impact-outcomes-section">
  <div class="impact-outcomes-inner">
    <div class="content-column">
      <h2>Impact & Outcomes</h2>
      <p class="lead-text">
        What we aim to achieve by the end of the 3-day summit.
      </p>

      <div class="outcomes-grid">
        {
          outcomes.map((outcome) => (
            <article class="outcome-card">
              <div class="outcome-icon" set:html={outcome.icon} />
              <div class="outcome-copy">
                <h3>{outcome.title}</h3>
                <p>{outcome.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="image-column">
      <div class="image-wrapper">
        <img src={impactImage.src} alt="LCOY Nepal impact and outcomes" />
        <div class="impact-badge">
          <span>100% IMPACT</span>
          <span>FOCUS</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .impact-outcomes-section {
    background: #00442d;
    padding: 96px 0;
  }

  .impact-outcomes-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 40px;
    align-items: center;
  }

  .content-column {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .content-column h2 {
    margin: 0 0 32px;
    font-family: "Poppins", sans-serif;
    font-size: 32px;
    line-height: 41.6px;
    font-weight: 600;
    color: #ffffff;
  }

  .lead-text {
    margin: 0 0 32px;
    font-family: "DM Sans", sans-serif;
    font-size: 18px;
    line-height: 28.8px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
  }

  .outcomes-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    width: 100%;
  }

  .outcome-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    padding: 24px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 16px;
  }

  .outcome-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .outcome-copy {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .outcome-copy h3 {
    margin: 0;
    font-family: "Poppins", sans-serif;
    font-size: 16px;
    line-height: 24px;
    font-weight: 700;
    color: #ffffff;
  }

  .outcome-copy p {
    margin: 0;
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    line-height: 20px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
  }

  .image-column {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .image-wrapper {
    position: relative;
  }

  .image-wrapper img {
    max-width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  .impact-badge {
    position: absolute;
    top: 0;
    right: 0;
    transform: rotate(12deg) translate(15%, -30%);
    width: 128px;
    height: 128px;
    border-radius: 50%;
    background: #e5b63b;
    padding: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .impact-badge span {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    line-height: 20px;
    font-weight: 700;
    color: #00442d;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .impact-outcomes-inner {
      grid-template-columns: 1fr;
    }

    .image-column {
      width: 100%;
    }

    .image-wrapper {
      width: 100%;
    }

    .image-wrapper img {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .impact-outcomes-section {
      padding: 72px 0;
    }

    .impact-outcomes-inner {
      padding: 0 24px;
      gap: 24px;
    }

    .outcomes-grid {
      grid-template-columns: 1fr;
    }

    .impact-badge {
      width: clamp(72px, 22vw, 104px);
      height: clamp(72px, 22vw, 104px);
      right: -12px;
      top: 12px;
      padding: clamp(8px, 2vw, 16px);
    }

    .impact-badge span {
      font-size: clamp(9px, 2.6vw, 13px);
      line-height: 1.3;
    }
  }

  @media (max-width: 480px) {
    .impact-badge {
      width: 60px;
      height: 60px;
      right: -8px;
      top: 8px;
      transform: rotate(12deg) translate(10%, -25%);
    }

    .impact-badge span {
      font-size: 10px;
    }
  }
</style>
