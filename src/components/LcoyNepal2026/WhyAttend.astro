<style>
  .why-attend-section {
    padding: 96px 0;
    background: #F8FAF6;
  }

  .why-attend-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .section-title {
    margin: 0 0 48px;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(28px, 2.5vw, 36px);
    line-height: 1.2;
    font-weight: 600;
    color: #00442D;
    text-align: center;
  }

  .why-attend-grid {
    display: flex;
    gap: 24px;
    align-items: stretch;
  }

  .why-attend-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    padding: 32px;
    border: 1px solid rgba(0, 68, 45, 0.12);
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(0, 68, 45, 0.05);
  }

  .icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-green {
    background: rgba(0, 68, 45, 0.1);
  }

  .icon-coral {
    background: rgba(240, 108, 93, 0.1);
  }

  .icon-gold {
    background: rgba(229, 182, 59, 0.1);
  }

  .card-copy {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }

  .card-copy h3 {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: 20px;
    line-height: 30px;
    font-weight: 500;
    color: #00442D;
  }

  .card-copy p {
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    line-height: 28.8px;
    font-weight: 400;
    color: #4B554C;
  }

  @media (max-width: 1024px) {
    .why-attend-grid {
      flex-direction: column;
    }
  }

  @media (max-width: 768px) {
    .why-attend-section {
      padding: 72px 0;
    }

    .why-attend-inner {
      padding: 0 24px;
    }

    .section-title {
      margin-bottom: 32px;
    }

    .why-attend-card {
      padding: 24px;
    }
  }
</style>
