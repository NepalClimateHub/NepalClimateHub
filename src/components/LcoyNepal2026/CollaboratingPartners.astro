---
import {
  aslf,
  byan,
  nch,
  Resilience_labs,
  swiof,
  unicef,
  wff,
  wycj,
  ycgn,
  ycnn,
  yasen,
  nyca,
  fao,
  icimod,
  koica,
  yuwa,
  prc,
  unfpa,
  planInternational,
} from "../../assets/lcoy/logo/partners";

const strategicPartners = [
  {
    logo: unicef,
  },
];

const inclusionPartners = [
  {
    logo: byan,
  },
];

const youthPartners = [
  {
    logo: aslf,
  },
  {
    logo: byan,
  },
  {
    logo: ycnn,
  },
  {
    logo: nch,
  },
  {
    logo: Resilience_labs,
  },
  {
    logo: swiof,
  },
  {
    logo: wff,
  },
  {
    logo: ycgn,
  },
  {
    logo: wycj,
  },
];
---

<section id="partners" class="partners-section">
  <div class="partners-inner">
    {/* Organized By */}
    <div class="partner-group">
      <p class="partner-category">Organized by</p>
      <div class="partners-flex">
        <div class="partner-card">
          <img src={yasen.src} alt="YASEN" />
        </div>
        <div class="partner-card">
          <img src={nyca.src} alt="NYCA" />
        </div>
      </div>
    </div>

    {/* In Partnership With */}
    <div class="partner-group">
      <p class="partner-category">In partnership with</p>
      <div class="partners-flex">
        <div class="partner-card">
          <img src={unicef.src} alt="UNICEF" />
        </div>
        <div class="partner-card">
          <img src={fao.src} alt="FAO" />
        </div>
        <div class="partner-card">
          <img src={icimod.src} alt="ICIMOD" />
        </div>
      </div>
    </div>

    {/* Knowledge Partners */}
    <div class="partner-group knowledge-partners-section">
      <p class="partner-category">Knowledge partners</p>
      <div class="knowledge-partners-container">
        <div class="knowledge-partners-flex">
          <img src={koica.src} alt="KOICA" class="knowledge-partner-logo" />
          <img
            src={planInternational.src}
            alt="UNFPA"
            class="knowledge-partner-logo"
          />
          <img src={yuwa.src} alt="YUWA" class="knowledge-partner-logo" />
          <img src={prc.src} alt="PRC" class="knowledge-partner-logo" />
          <img src={unfpa.src} alt="UNFPA" class="knowledge-partner-logo" />
        </div>
      </div>
    </div>

    {/* Youth Partners */}
    <div class="partner-group">
      <p class="partner-category">youth partners</p>
      <div class="partners-flex large-group">
        {
          youthPartners.map((partner) => (
            <div class="partner-card">
              {partner.logo ? (
                <img class="partner-logo" src={partner.logo.src} />
              ) : (
                <span class="partner-logo-text">PARTNER LOGO</span>
              )}
            </div>
          ))
        }
      </div>
    </div>

    {/* CTA Text */}
    <p class="cta-text">
      Contact <a href="mailto:sponsors@lcoynepal.org">lcoynepalhost@gmail.com</a
      >
    </p>
  </div>
</section>

<style>
  .partners-section {
    background: #f8faf6;
    padding: 120px 0;
  }

  .partners-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 64px;
  }

  .section-title {
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 32px;
    line-height: 41.6px;
    letter-spacing: 0px;
    text-align: center;
    color: #00442d;
    margin: 0 0 64px 0;
  }

  .partner-group {
    margin-bottom: 96px;
  }

  .partner-group:last-child {
    margin-bottom: 0;
  }

  .partner-category {
    font-family: "DM Sans", sans-serif;
    font-weight: 700;
    font-size: 20px;
    line-height: 12px;
    letter-spacing: 1.2px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color: #404943;
    margin: 0 0 32px 0;
  }

  .partners-flex {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  .partner-logo {
    object-fit: contain;
    height: 100%;
  }

  .partners-flex.large-group {
    gap: 32px;
  }

  .partners-flex.organizers-flex {
    gap: 48px;
  }

  .partner-card {
    width: 250px;
    aspect-ratio: 2 / 1;
    border-radius: 16px;
    border: 1px solid #bfc9c14d;
    background: #ffffff;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .partner-card img {
    max-width: 180px;
    max-height: 100%;
    object-fit: contain;
  }

  .title-partner-card {
    width: 192px;
    aspect-ratio: 2 / 1;
    border-radius: 16px;
    border: 1px solid #bfc9c14d;
    background: #ffffff;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .title-partner-card img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .organizer-card {
    width: 384px;
    aspect-ratio: 2 / 1;
    border-radius: 16px;
    border: 1px solid #bfc9c14d;
    background: #ffffff;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    max-height: 210px;
  }

  .organizer-card img {
    object-fit: contain;
    max-width: 161px;
  }

  .partner-logo-text {
    font-family: "DM Sans", sans-serif;
    font-weight: 400;
    font-size: 10px;
    line-height: 15px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color: #94a3b8;
  }

  .title-partner-card,
  .partner-card,
  .organizer-card {
    position: relative;
  }

  .cta-text {
    font-family: "DM Sans", sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 24px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    color: #00442d;
    margin: 112px 0;
  }

  .cta-text a {
    color: #00442d;
    font-weight: 500;
  }

  .cta-text a:hover {
    text-decoration: underline;
  }

  /* Knowledge Partners Section */
  .knowledge-partners-container {
    background: #ffffff;
    border: 1px solid #bfc9c14d;
    border-radius: 16px;
    padding: 48px;
    margin: 0 auto;
    max-width: 900px;
  }

  .knowledge-partners-flex {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 40px;
    max-width: 540px;
    margin: 0 auto;
  }

  .knowledge-partner-logo {
    height: 75px;
    max-width: 140px;
    object-fit: contain;
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .partners-inner {
      padding: 0 48px;
    }

    .title-partner-card {
      max-width: 160px;
    }

    .partner-card {
      max-width: 160px;
    }

    .organizer-card {
      max-width: 300px;
    }

    .partners-flex {
      gap: 16px;
    }

    .partners-flex.large-group {
      gap: 20px;
    }

    .partner-group {
      margin-bottom: 64px;
    }

    .knowledge-partners-container {
      padding: 32px;
    }

    .knowledge-partners-flex {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px 48px;
    }

    .knowledge-partner-logo {
      height: 60px;
      max-width: 120px;
    }
  }

  @media (max-width: 768px) {
    .partners-section {
      padding: 80px 0;
    }

    .partners-inner {
      padding: 0 32px;
    }

    .section-title {
      font-size: 24px;
      line-height: 32px;
      margin-bottom: 48px;
    }

    .partner-category {
      font-size: 16px;
      margin-bottom: 24px;
    }

    .title-partner-card {
      max-width: 140px;
    }

    .partner-card {
      max-width: 140px;
    }

    .organizer-card {
      max-width: 250px;
    }

    .partner-group {
      margin-bottom: 48px;
    }

    .cta-text {
      font-size: 16px;
      line-height: 20px;
      margin: 48px 0;
    }

    .partners-flex {
      gap: 12px;
    }

    .partners-flex.large-group {
      gap: 16px;
    }

    .knowledge-partners-container {
      padding: 24px;
    }

    .knowledge-partners-flex {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 40px;
    }

    .knowledge-partner-logo {
      height: 50px;
      max-width: 100px;
    }
  }

  @media (max-width: 480px) {
    .partners-section {
      padding: 60px 0;
    }

    .partners-inner {
      padding: 0 16px;
    }

    .section-title {
      font-size: 20px;
      line-height: 28px;
      margin-bottom: 32px;
    }

    .partner-category {
      font-size: 14px;
      margin-bottom: 16px;
    }

    .title-partner-card {
      max-width: 100%;
    }

    .partner-card {
      /* max-width: 120px; */
    }

    .organizer-card {
      max-width: 100%;
    }

    .partner-group {
      margin-bottom: 32px;
    }

    .cta-text {
      font-size: 14px;
      line-height: 18px;
      margin: 32px 0;
    }

    .partners-flex {
      gap: 8px;
    }

    .partners-flex.large-group {
      gap: 12px;
    }

    .partners-flex.organizers-flex {
      gap: 24px;
    }

    .knowledge-partners-container {
      padding: 20px;
    }

    .knowledge-partners-flex {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px 24px;
    }

    .knowledge-partner-logo {
      height: 40px;
      max-width: 80px;
    }
  }
</style>
