<section class="cta-section">
  <div class="cta-card">
    <div class="cta-left">
      <h2 class="cta-title">Join the Movement</h2>
      <p class="cta-description">
        For students, researchers, entrepreneurs, activists, and organizers ready to move from discussion to impact. Eligibility: Aged 16-35 · Based in Nepal · Passionate about climate action · Committed to learning and collaboration. Deadline: 31 July 2026 · Free for selected delegates.
      </p>
    </div>
    <div class="cta-right">
      <a href="#apply" class="cta-button">APPLY NOW</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: #F8FAF6;
    padding: 88px 16px;
  }

  .cta-card {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 24px;
    padding: 80px;
    background: linear-gradient(90deg, #38B2AC 0%, #00442D 100%);
    gap: 48px;
  }

  .cta-left {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .cta-title {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 32px;
    line-height: 41.6px;
    letter-spacing: 0px;
    color: white;
    margin: 0 0 24px 0;
  }

  .cta-description {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 28.8px;
    letter-spacing: 0px;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    max-width: 600px;
  }

  .cta-right {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: white;
    color: #00442D;
    border-radius: 16px;
    padding: 20px 40px;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 30px;
    letter-spacing: 0px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(56, 178, 172, 0.3);
  }

  .cta-button:active {
    transform: translateY(0);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .cta-card {
      padding: 60px;
      gap: 32px;
    }

    .cta-title {
      font-size: 28px;
      line-height: 36px;
    }

    .cta-description {
      font-size: 16px;
      line-height: 26px;
    }

    .cta-button {
      padding: 18px 36px;
      font-size: 18px;
    }
  }

  @media (max-width: 768px) {
    .cta-section {
      padding: 64px 16px;
    }

    .cta-card {
      flex-direction: column;
      align-items: stretch;
      padding: 48px;
      gap: 24px;
    }

    .cta-left {
      align-items: center;
      text-align: center;
    }

    .cta-title {
      font-size: 24px;
      line-height: 32px;
      margin-bottom: 16px;
    }

    .cta-description {
      font-size: 14px;
      line-height: 22px;
      max-width: 100%;
    }

    .cta-right {
      width: 100%;
      justify-content: center;
    }

    .cta-button {
      width: 100%;
      padding: 16px 32px;
      font-size: 16px;
    }
  }

  @media (max-width: 480px) {
    .cta-section {
      padding: 48px 16px;
    }

    .cta-card {
      border-radius: 16px;
      padding: 32px;
      gap: 16px;
    }

    .cta-title {
      font-size: 20px;
      line-height: 28px;
      margin-bottom: 12px;
    }

    .cta-description {
      font-size: 12px;
      line-height: 18px;
    }

    .cta-button {
      padding: 14px 28px;
      font-size: 14px;
    }
  }
</style>
