---
import '../../styles/global.css';
import BaseLayout from '../../layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getProject, fetchAllProjects } from '../../api';
import { createSlug } from '../../utils/slug';
import type { Project } from '../../types/project';
import HtmlRenderer from '@components/HtmlRenderer.astro';
import { RiAlarmLine } from 'react-icons/ri';

const { details } = Astro.params;
let project: Project | undefined;
let otherProjects: Project[] = [];

if(!details) {
  return notFound();
}

try {
  project = await getProject(details);
} catch (error) {
  console.error('Error fetching project:', error);
}

if (!project) {
  return Astro.redirect('/our-work');
}

try {
  const response = await fetchAllProjects();
  otherProjects = (response.data || [])
    .filter((p) => createSlug(p.title) !== details)
    .slice(0, 4);
} catch (error) {
  console.error('Error fetching other projects:', error);
}
---
<!-- <link
  href="https://fonts.googleapis.com/css2?family=Zilla+Slab:wght@400;700&display=swap"
  rel="stylesheet"
/> -->

<BaseLayout title={`${project.title} | Nepal Climate Hub`}>
  <main class="main-container">
    <!-- Header Section -->
    <section class="header-section">
      <Header logoColor="#1A1B1E" />
      <div class="mini-nav">
        <a href="/">Home</a>
        <span style="color: #364FC7">/</span>
        <a href="/our-work">Our Work</a>
      </div>
    </section>

    <!-- Project Image -->
    <section class="project-image-section">
      <img src={project.bannerImageUrl} alt={project.title} />
    </section>

    <!-- Project Details -->
    <section class="project-details-section">
      <div class="project-container section-container">
        <!-- Status Badge & Title -->
        <div class="project-header">
          <span class="status-badge">{project.status.toLowerCase()}</span>
          <h1 class="project-title">{project.title}</h1>
        </div>

        <!-- Duration Section -->
        <div class="content-section">
          <div class="section-label">Status</div>
          <div class="section-content">
            <span class="status-badge">{project.status.toLowerCase()}</span>
          </div>
        </div>

        <!-- Overview Section -->
        <div class="content-section">
          <div class="section-label">Overview</div>
          <div class="section-content">
            <p>{project.overview}</p>
          </div>
        </div>

        <!-- Description Section -->
        <div class="content-section">
          <div class="section-label">Description</div>
          <div class="section-content">
            <HtmlRenderer content={project.description} />
          </div>
        </div>
      </div>
    </section>

    <!-- Other Works Section -->
    <section class="our-work-section">
      <div class="section-container">
        <h2 class="section-title">Other works</h2>

        <div class="grid">
          {otherProjects.map((project) => (
            <a href={`/our-work/${createSlug(project.title)}`} class="card-link">
              <div class="card">
                <div class="card-image">
                  <img src={project.bannerImageUrl} alt={project.title} />
                </div>
                <div class="card-content">
                  <h3 class="card-title">{project.title}</h3>
                  <p class="card-overview">
                    <span class="overview-label">Overview:</span> {project.overview}
                  </p>

                  <div class="card-duration">
                    <RiAlarmLine size={15} />
                    <span class="duration-text">
                      <span class="duration-label">Duration:</span> {project.duration}
                    </span>
                  </div>

                  <div class="card-tags">
                    {project.tags.map((tag) => (
                      <span class="tag">{tag.tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer Section -->
    <section class="footer-section">
      <Footer />
    </section>
  </main>
</BaseLayout>

<style>
  .header-section {
    padding: 0px 48px;
  }

  /* Project Image Section */
  .project-image-section {
    width: 100%;
    aspect-ratio: 3;
    overflow: hidden;
  }

  .project-image-section img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Project Details Section */
  .project-details-section {
    padding: 48px;
    background-color: #ffffff;
  }

  .project-container {
    margin: 0 auto;
  }

  .project-header {
    margin-bottom: 48px;
  }

  .status-badge {
    display: inline-block;
    padding: 4px 12px;
    background-color: transparent;
    border: 1px solid #cefe00;
    border-radius: 20px;
    font-size: 12px;
    color: #364fc7;
    font-weight: 500;
    margin-bottom: 8px;
    text-transform: capitalize;
    height: fit-content;
    width: fit-content;
  }

  .project-title {
    font-size: 1.75rem;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    color: #000;
    font-family: "Zilla Slab", serif;
    font-weight: bold;
    line-height: 36px;
    font-size: 30px;
  }

  /* Content Sections */
  .content-section {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 32px;
    margin-bottom: 48px;
    align-items: flex-start;
  }

  .section-label {
    font-size: 18px;
    font-weight: 700;
    color: #1a1b1e;
  }

  .section-content {
    font-size: 16px;
    color: #464646;
    line-height: 24px;
  }

  .status-badge-detail {
    display: inline-block;
  }
  
  /* Our Work Section */
  .our-work-section {
    padding: 35px 48px;
    background-color: #ffffff;
  }

  .section-container {
    /* max-width: 984px; */
    margin: 0 auto;
  }

  .section-title {
    font-size: 24px;
    color: #1a1b1e;
    line-height: 32px;
    margin: 0 0 32px 0;
    font-weight: 700;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 110px;
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card-link:hover {
    transform: translateY(-4px);
  }

  .card-link:hover .card {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .card {
    border-radius: 12px;
    padding: 12px;
    background-color: #f8f9fa;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .card-image {
    width: 100%;
    height: 200px;
    margin-bottom: 12px;
    border-radius: 8px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card-title {
    font-size: 16px;
    color: #1a1b1e;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
  }

  .card-overview {
    font-size: 12px;
    color: #464646;
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .overview-label {
    font-weight: 700;
  }

  .card-duration {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #464646;
  }

  .card-duration :global(svg) {
    color: #d9d9d9;
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }

  .duration-text {
    display: flex;
    gap: 4px;
  }

  .duration-label {
    font-weight: 700;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .tag {
    padding: 4px 9px;
    background-color: transparent;
    border: 1px solid #cefe00;
    border-radius: 20px;
    font-size: 12px;
    color: #364fc7;
    font-weight: 500;
  }

  .footer-section {
    background-color: #1a1b1e;
    color: white;
  }

  /* Responsive */
  @media screen and (max-width: 1280px) {
    .project-details-section {
      padding: 35px 24px;
    }

    .grid {
      grid-template-columns: 1fr 1fr;
      margin-bottom: 80px;
    }
  }

  @media screen and (max-width: 768px) {
    .project-image-section {
      aspect-ratio: auto;
      height: 250px;
    }

    .project-details-section {
      padding: 24px;
    }

    .project-header {
      margin-bottom: 32px;
    }

    .project-title {
      font-size: 24px;
    }

    .content-section {
      grid-template-columns: 1fr;
      gap: 16px;
      margin-bottom: 32px;
    }

    .section-label {
      font-size: 16px;
    }

    .section-content {
      font-size: 14px;
    }

    .our-work-section {
      padding: 24px;
    }

    .section-title {
      font-size: 18px;
      margin-bottom: 24px;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-bottom: 48px;
    }

    .card {
      padding: 12px;
    }
  }
</style>
