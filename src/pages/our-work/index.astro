---
import '../../styles/global.css';
import OurWorkHeroSection from '@components/OurWorkHeroSection.astro';
import OurWorkWhatWeDo from '@components/OurWorkWhatWeDo.astro';
import OurWorkExplore from '@components/OurWorkExplore.astro';
import OurWorkBuildWithUs from '@components/OurWorkBuildWithUs.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import BaseLayout from "../../layouts/Layout.astro";
import { fetchAllProjects } from '../../api';
import type { Project } from '../../types/project';

let projects: Project[] = [];

try {
  const response = await fetchAllProjects();
  projects = response.data || [];
} catch (error) {
  console.error('Error fetching projects:', error);
}

---

<BaseLayout title="Our Work | Nepal Climate Hub">
  <main class="main-container">
    <!-- Header Section -->
    <section class="header-section">
      <Header logoColor="#1A1B1E" />
      <div class="mini-nav">
        <a href="/">Home</a>
      </div>
    </section>

    <section class="ourwork-hero-section">
      <OurWorkHeroSection />
    </section>

    <section class="ourwork-whatwedo-section">
      <OurWorkWhatWeDo />
    </section>

    <section class="ourwork-explore-section">
      <OurWorkExplore projects={projects} />
    </section>

    <section class="ourwork-build-with-us-section">
      <OurWorkBuildWithUs />
    </section>

    <section class="footer-section">
      <Footer />
    </section>
  </main>
</BaseLayout>

<style>
  .header-section {
    padding: 0px 48px;
  }

  .ourwork-whatwedo-section {
    background-color: #f8f9fa;
  }

  .footer-section {
    background-color: #1a1b1e;
    color: white;
  }

  @media screen and (max-width: 768px) {
    .header-section {
      padding: 0px;
    }
  }
</style>
