---
import '../styles/global.css';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import DonateContributionSection from '@components/DonateContributionSection.astro';
import DonateHeroSection from '@components/DonateHeroSection.astro';
import DonateHowUsedSection from '@components/DonateHowUsedSection.astro';
import DonateWaysSupportSection from '@components/DonateWaysSupportSection.astro';
import DonateWhySupportSection from '@components/DonateWhySupportSection.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout title="Donate | Nepal Climate Hub">
  <main class="main-container">
    <!-- header section  -->
    <section class="header-section">
      <Header logoColor="#1A1B1E" />

        <Breadcrumbs
          data={[
            { label: "Donate"},
          ]}
      />
   
    </section>

    <section class="donate-hero-section">
      <DonateHeroSection />
    </section>

        <section class="donate-why-support-section">
      <DonateWhySupportSection />
    </section>

    <section class="donate-how-used-section">
      <DonateHowUsedSection />
    </section>


    <section class="donate-contribution-section">
      <DonateContributionSection />
    </section>

    <section class="donate-ways-support-section">
      <DonateWaysSupportSection />
    </section>



    <section class="footer-section">
      <Footer />
    </section>
  </main>
</BaseLayout>

<style>
  .header-section {
    padding: 0px 48px;
  }

  .footer-section {
    background-color: #1a1b1e;
    color: white;
  }

  @media screen and (max-width: 768px) {
    .header-section {
      padding: 0px;
    }
  }
</style>

