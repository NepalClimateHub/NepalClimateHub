---
import '../styles/global.css';
import Header from '@components/Header.astro';
import FellowshipHeroSection from '@components/FellowshipHeroSection.astro';
import FellowshipProblemSection from '@components/FellowshipProblemSection.astro';
import FellowshipEvidenceSection from '@components/FellowshipEvidenceSection.astro';
import FellowshipAboutSection from '@components/FellowshipAboutSection.astro';
import FellowshipJourneySection from '@components/FellowshipJourneySection.astro';
import FellowshipQualificationsSection from '@components/FellowshipQualificationsSection.astro';
import FellowshipBenefitsSection from '@components/FellowshipBenefitsSection.astro';
import FellowshipTeamSection from '@components/FellowshipTeamSection.astro';
import FellowshipApplicationProcessSection from '@components/FellowshipApplicationProcessSection.astro';
import Footer from '@components/Footer.astro';
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout title="Fellowship | Nepal Climate Hub">
  <main class="main-container">
    <!-- Header Section -->
    <section class="header-section">
      <Header logoColor="#1A1B1E" />
      <div class="mini-nav">
        <a href="/">Home</a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="fellowship-hero-section">
      <FellowshipHeroSection />
    </section>

    <!-- Problem Section -->
    <section class="fellowship-problem-section">
      <FellowshipProblemSection />
    </section>

    <!-- Evidence Section -->
    <section class="fellowship-evidence-section">
      <FellowshipEvidenceSection />
    </section>

    <!-- About Section -->
    <section class="fellowship-about-section">
      <FellowshipAboutSection />
    </section>

    <!-- Journey Section -->
    <section class="fellowship-journey-section">
      <FellowshipJourneySection />
    </section>

    <!-- Qualifications Section -->
    <section class="fellowship-qualifications-section">
      <FellowshipQualificationsSection />
    </section>

    <!-- Benefits Section -->
    <section class="fellowship-benefits-section">
      <FellowshipBenefitsSection />
    </section>

    <!-- Team Section (Mentors & Speakers) -->
    <section class="fellowship-team-section">
      <FellowshipTeamSection />
    </section>

    <!-- Application Process Section -->
    <section class="fellowship-application-process-section">
      <FellowshipApplicationProcessSection />
    </section>

    <!-- Footer Section -->
    <section class="footer-section">
      <Footer />
    </section>
  </main>
</BaseLayout>

<style>
  /* Header section — standard across all non-home pages */
  .header-section {
    padding: 0px 48px;
  }

  /* Hero wrapper: dark bg, vertical padding */
  .fellowship-hero-section {
    background-color: #1A1B1E;
    padding: 78px 44px;
  }

  /* Problem section */
  .fellowship-problem-section {
    background-color: #364FC7;
    padding: 78px 44px;
    position: relative;
    overflow: hidden;
  }

  /* Evidence section */
  .fellowship-evidence-section {
    background-color: #FFFFFF;
    padding: 78px 44px;
  }

  /* About section */
  .fellowship-about-section {
    background-color: #F8F9FA;
    padding: 78px 44px;
  }

  /* Journey section */
  .fellowship-journey-section {
    background-color: #FFFFFF;
    padding: 78px 44px;
  }

  /* Qualifications section */
  .fellowship-qualifications-section {
    background-color: #F5F5F5;
    padding: 78px 44px;
  }

  /* Benefits section */
  .fellowship-benefits-section {
    background-color: #F8F9FA;
    padding: 78px 44px;
  }

  /* Team section */
  .fellowship-team-section {
    background-color: #FFFFFF;
    padding: 78px 44px;
  }

  /* Application Process section */
  .fellowship-application-process-section {
    background-color: #364FC7;
    padding: 78px 44px;
  }

  /* Footer section */
  .footer-section {
    background-color: #1a1b1e;
    color: white;
  }

  /* Responsive */
  @media screen and (max-width: 1024px) {
    .fellowship-hero-section { padding: 64px 32px; }
    .fellowship-problem-section { padding: 64px 32px; }
    .fellowship-evidence-section { padding: 64px 32px; }
    .fellowship-about-section { padding: 64px 32px; }
    .fellowship-journey-section { padding: 64px 32px; }
    .fellowship-qualifications-section { padding: 64px 32px; }
    .fellowship-benefits-section { padding: 64px 32px; }
    .fellowship-team-section { padding: 64px 32px; }
    .fellowship-application-process-section { padding: 64px 32px; }
  }

  @media screen and (max-width: 768px) {
    .header-section { padding: 0px; }
    .fellowship-hero-section { padding: 48px 24px; }
    .fellowship-problem-section { padding: 48px 24px; }
    .fellowship-evidence-section { padding: 48px 24px; }
    .fellowship-about-section { padding: 48px 24px; }
    .fellowship-journey-section { padding: 48px 24px; }
    .fellowship-qualifications-section { padding: 48px 24px; }
    .fellowship-benefits-section { padding: 48px 24px; }
    .fellowship-team-section { padding: 48px 24px; }
    .fellowship-application-process-section { padding: 48px 24px; }
  }
</style>
