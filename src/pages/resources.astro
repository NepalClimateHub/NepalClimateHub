---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import CardFilterSection from '../layouts/CardFilterSection.astro';
import ResourceFilter from '../components/ResourceFilter';
import BaseLayout from '../layouts/Layout.astro';
import Loader from '../components/Loader.astro';
import resourceJSON from '../data/resources.json';
---

<BaseLayout title="Nepal Climate Hub">
  <main class="main-container">
    <section class="header-section">
      <Header logoColor="#1A1B1E" />
      <div class="mini-nav">
        <a href="/">Home</a>
      </div>
    </section>

    <div class="resource-wrapper">
      <section class="filter-section">
        <CardFilterSection heading="Climate Resources" type="resource" filter={false} />
      </section>

      <section class="resource-cards-section">
        <ResourceFilter client:load resources={resourceJSON} />
      </section>
    </div>

    <section class="footer-section">
      <Footer />
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding: 0px 48px;
  }

  .resource-wrapper {
    background-color: #ffffff;
  }

  .footer-section {
    background-color: #1a1b1e;
    color: white;
  }

  @media screen and (max-width: 768px) {
    section {
      padding: 0px;
    }

    .resource-cards-section {
      padding: 0;
    }
  }
</style>
